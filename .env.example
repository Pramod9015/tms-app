# Environment — copy to .env and fill in values
# NEVER commit the .env file, only .env.example

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (local dev, auto-created):
DATABASE_URL=sqlite+aiosqlite:///./tms_dev.db

# PostgreSQL (production — Render provides this):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/tms

# ── Encryption keys (KEEP SECRET) ────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AES_ENCRYPTION_KEY=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Admin bootstrap (created on first run) ───────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123!
ADMIN_EMAIL=admin@tms.local

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Gemini Vision API (for slip OCR) ─────────────────────────────────────────
# Get free key from: https://aistudio.google.com/
GEMINI_API_KEY="AIzaSyB7l3F3EvzYqhYMh4LZ3088u48kMcydE-s"
